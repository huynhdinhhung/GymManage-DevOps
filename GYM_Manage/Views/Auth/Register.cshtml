@model GYM_Manage.Models.NguoiDung
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-3">

                <!-- HEADER -->
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="fw-bold mb-0">
                        <i class="bi bi-person-plus-fill me-2"></i>Đăng ký tài khoản
                    </h3>
                    <p class="mb-0 mt-2">Tạo tài khoản để bắt đầu hành trình fitness của bạn</p>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    <!-- THÔNG BÁO -->
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }

                    <form asp-action="Register" method="post">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- THÔNG TIN CÁ NHÂN -->
                        <h5 class="fw-bold mb-3">Thông tin cá nhân</h5>

                        <!-- HỌ TÊN -->
                        <div class="form-floating mb-3">
                            <input asp-for="HoTen" class="form-control" placeholder="Họ và tên" />
                            <label>Họ và tên</label>
                            <span asp-validation-for="HoTen" class="text-danger"></span>
                        </div>

                        <!-- EMAIL -->
                        <div class="form-floating mb-4">
                            <input asp-for="Email" class="form-control" placeholder="Email" type="email" />
                            <label>Email</label>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <h5 class="fw-bold mt-4 mb-3">Thông tin tài khoản</h5>

                        <!-- TÊN ĐĂNG NHẬP -->
                        <div class="form-floating mb-3">
                            <input asp-for="TenDangNhap" class="form-control" placeholder="Tên đăng nhập" />
                            <label>Tên đăng nhập</label>
                            <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <!-- MẬT KHẨU -->
                                <div class="form-floating mb-3">
                                    <input asp-for="MatKhau" class="form-control" type="password" id="pw" placeholder="Mật khẩu" />
                                    <label>Mật khẩu</label>
                                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <!-- XÁC NHẬN MẬT KHẨU -->
                                <div class="form-floating mb-3">
                                    <input type="password" class="form-control" id="pw2" placeholder="Xác nhận mật khẩu" />
                                    <label>Xác nhận mật khẩu</label>
                                </div>
                            </div>
                        </div>

                        <div id="pwError" class="text-danger mb-3" style="display:none;">
                            Mật khẩu xác nhận không khớp!
                        </div>

                        <!-- CHECKBOX -->
                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="agree" required>
                            <label class="form-check-label" for="agree">
                                Tôi đồng ý với <a href="#" class="text-decoration-none">điều khoản</a> và <a href="#" class="text-decoration-none">chính sách bảo mật</a>
                            </label>
                        </div>

                        <!-- SUBMIT -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" id="btnSubmit">
                                <i class="bi bi-check-circle-fill me-2"></i>Đăng ký
                            </button>
                        </div>

                    </form>

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center bg-light py-3">
                    <p class="mb-0">
                        Đã có tài khoản?
                        <a href="/Auth/Login" class="text-decoration-none">Đăng nhập ngay</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // kiểm tra mật khẩu
        document.getElementById("pw2").addEventListener("input", function () {
            const pw = document.getElementById("pw").value;
            const repw = this.value;

            if (pw !== repw) {
                document.getElementById("pwError").style.display = "block";
                document.getElementById("btnSubmit").disabled = true;
            } else {
                document.getElementById("pwError").style.display = "none";
                document.getElementById("btnSubmit").disabled = false;
            }
        });
    </script>
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: #f0f2f5;
        }

        .card {
            border-radius: 1rem;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }
    </style>
}
