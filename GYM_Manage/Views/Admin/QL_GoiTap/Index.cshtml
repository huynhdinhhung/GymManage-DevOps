@model IEnumerable<GYM_Manage.Models.GoiTap>
@{
    ViewData["Title"] = "Quản lý gói tập";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="fw-bold m-0">@ViewData["Title"]</h4>

        <div class="d-flex gap-2">
            <form asp-action="Search" method="get" class="d-flex">
                <input name="keyword" class="form-control me-2" placeholder="Tìm theo tên, mô tả hoặc loại gói..." />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-search"></i> Tìm
                </button>
            </form>

            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm gói
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:90px">Ảnh</th>
                        <th>Tên gói</th>
                        <th>Loại</th>
                        <th>Thời hạn</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th style="width:160px" class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(g.AnhDemo))
                                {
                                    <img src="@g.AnhDemo" alt="Ảnh" class="img-thumbnail" style="height:64px;object-fit:cover" />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>

                            <td>
                                <div class="fw-semibold">@g.TenGoiTap</div>
                                <div class="small text-muted">@g.MoTa</div>
                            </td>

                            <td>
                                @if (g.LoaiGoi == "VIP")
                                {
                                    <span class="badge bg-warning text-dark">VIP</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Thường</span>
                                }
                            </td>

                            <td>@g.ThoiHan ngày</td>
                            <td>@String.Format("{0:N0}₫", g.GiaTien)</td>

                            <td>
                                @{
                                    string cls = g.TrangThai switch
                                    {
                                        "Đang hoạt động" => "bg-success",
                                        "Khuyến mãi" => "bg-info",
                                        "Ngưng hoạt động" => "bg-secondary",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge @cls">@g.TrangThai</span>
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@g.MaGoiTap" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>

                                <form asp-action="Delete" asp-route-id="@g.MaGoiTap" method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xoá gói này không?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Xoá
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
