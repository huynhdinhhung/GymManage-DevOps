@model GYM_Manage.Models.GoiTap
@{
    var isEdit = Model?.MaGoiTap > 0;
    ViewData["Title"] = isEdit ? "Chỉnh Sửa Gói Tập" : "Thêm Mới Gói Tập";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <h4 class="mb-4 fw-bold">@ViewData["Title"]</h4>

    <div class="card shadow">
        <div class="card-header">
            <strong>Thông tin gói tập</strong>
        </div>
        <div class="card-body">
            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @if (isEdit)
                {
                    <input type="hidden" asp-for="MaGoiTap" />
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="TenGoiTap" class="form-label">Tên gói tập</label>
                        <input asp-for="TenGoiTap" class="form-control" required />
                        <span asp-validation-for="TenGoiTap" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ThoiHan" class="form-label">Thời hạn (ngày)</label>
                        <input asp-for="ThoiHan" type="number" min="1" class="form-control" required />
                        <span asp-validation-for="ThoiHan" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="GiaTien" class="form-label">Giá tiền (VND)</label>
                        <input asp-for="GiaTien" type="number" min="0" step="1000" class="form-control" required />
                        <span asp-validation-for="GiaTien" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TrangThai" class="form-label">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="Đang hoạt động">Đang hoạt động</option>
                            <option value="Ngưng hoạt động">Ngưng hoạt động</option>
                            <option value="Khuyến mãi">Khuyến mãi</option>
                        </select>
                        <span asp-validation-for="TrangThai" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="LoaiGoi" class="form-label">Loại gói</label>
                        <select asp-for="LoaiGoi" class="form-select">
                            <option value="Thuong">Thường</option>
                            <option value="VIP">VIP</option>
                        </select>
                        <span asp-validation-for="LoaiGoi" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="MoTa" class="form-label">Mô tả</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Ảnh minh hoạ</label>
                        <input type="file" name="anhDemo" accept="image/*" class="form-control" />
                        @if (!string.IsNullOrEmpty(Model?.AnhDemo))
                        {
                            <div class="mt-2">
                                <img src="@Model.AnhDemo" alt="Ảnh gói tập" class="img-thumbnail" style="max-height:200px;object-fit:cover" />
                                <div class="text-muted small">Ảnh hiện tại. Tải ảnh mới để thay đổi.</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
