@model GYM_Manage.Models.ThietBi
@{
    ViewData["Title"] = Model?.MaThietBi > 0 ? "Chỉnh Sửa Thiết Bị" : "Thêm Mới Thiết Bị";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <h4 class="mb-4">
        <span class="fw-bolder">@ViewData["Title"]</span>
    </h4>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold">Thông tin thiết bị</h6>
        </div>

        <div class="card-body">

            <form asp-action="@(Model?.MaThietBi > 0 ? "Edit" : "Create")"
                  method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @if (Model?.MaThietBi > 0)
                {
                    <input type="hidden" asp-for="MaThietBi" />
                }

                <div class="row mb-3">

                    <div class="col-md-6">

                        <!-- Tên thiết bị -->
                        <div class="form-group mb-3">
                            <label asp-for="TenThietBi" class="form-label">Tên thiết bị</label>
                            <input asp-for="TenThietBi" class="form-control" required />
                            <span asp-validation-for="TenThietBi" class="text-danger"></span>
                        </div>

                        <!-- Danh mục -->
                        <div class="form-group mb-3">
                            <label asp-for="DanhMuc" class="form-label">Danh mục</label>
                            <select asp-for="DanhMuc" class="form-select">
                                <option value="Cardio">Cardio</option>
                                <option value="Strength">Strength</option>
                                <option value="Functional">Functional</option>
                                <option value="Free Weights">Free Weights</option>
                                <option value="Accessories">Accessories</option>
                            </select>
                            <span asp-validation-for="DanhMuc" class="text-danger"></span>
                        </div>

                        <!-- Ảnh -->
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Hình ảnh thiết bị</label>

                            <input type="file" name="hinhAnh" class="form-control" accept="image/*" />

                            @if (!string.IsNullOrEmpty(Model?.HinhAnh))
                            {
                                <div class="mt-2">
                                    <p class="text-muted mb-1">Ảnh hiện tại:</p>
                                    <img src="@Model.HinhAnh" width="180" class="rounded border" />
                                </div>
                            }
                        </div>

                    </div>

                    <div class="col-md-6">

                        <!-- Ngày mua -->
                        <div class="form-group mb-3">
                            <label asp-for="NgayMua" class="form-label">Ngày mua</label>
                            <input asp-for="NgayMua" class="form-control" type="date" />
                            <span asp-validation-for="NgayMua" class="text-danger"></span>
                        </div>

                        <!-- Ngày bảo trì cuối -->
                        <div class="form-group mb-3">
                            <label asp-for="NgayBaoTriCuoi" class="form-label">Ngày bảo trì cuối</label>
                            <input asp-for="NgayBaoTriCuoi" class="form-control" type="date" />
                            <span asp-validation-for="NgayBaoTriCuoi" class="text-danger"></span>
                        </div>

                        <!-- Trạng thái -->
                        <div class="form-group mb-3">
                            <label asp-for="TrangThai" class="form-label">Trạng thái</label>
                            <select asp-for="TrangThai" class="form-select">
                                <option value="HoatDong">Hoạt động tốt</option>
                                <option value="BaoTri">Cần bảo trì</option>
                                <option value="SuaChua">Đang sửa chữa</option>
                                <option value="Ngung">Ngưng hoạt động</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Lưu
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
