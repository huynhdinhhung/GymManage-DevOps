@{
    ViewData["Title"] = "Không có lịch tập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 d-flex justify-content-center">
    <div class="card shadow-sm border-0" style="max-width: 600px; width: 100%;">
        <div class="card-body text-center py-5">

            <div class="text-warning mb-3">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 60px;"></i>
            </div>

            <h3 class="fw-bold">Bạn chưa đăng ký gói tập nào</h3>

            <p class="text-muted mt-2">
                Hãy chọn một gói tập phù hợp để bắt đầu hành trình tập luyện của bạn tại GYM Center.
            </p>

            <a href="/GoiTap/Index" class="btn btn-primary btn-lg mt-3 px-4">
                <i class="bi bi-cart-plus me-1"></i> Đăng ký gói tập ngay
            </a>
        </div>
    </div>
</div>
