@model IEnumerable<GYM_Manage.Models.LichLamViecHLV>

@{
    ViewData["Title"] = "Lịch tập chung";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var thongBao = ViewBag.ThongBao as List<GYM_Manage.Models.ThongBao>;
    var thongBaoMoi = ViewBag.ThongBaoMoi as int? ?? 0;
    var top3ThongBao = thongBao?.Take(3).ToList() ?? new List<GYM_Manage.Models.ThongBao>();
}

<div class="container py-4">
    <div class="row">

        <!-- Lịch tập bên trái -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar-week me-2"></i> Lịch tập chung của phòng tập
                    </h5>
                </div>

                <div class="card-body">
                    <table class="table table-bordered table-hover align-middle mt-2">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày</th>
                                <th>Ca</th>
                                <th>Huấn luyện viên</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NgayLamViec.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <b>@item.CaLamViec?.TenCa</b> <br />
                                        <small class="text-muted">
                                            @item.CaLamViec?.GioBatDau - @item.CaLamViec?.GioKetThuc
                                        </small>
                                    </td>
                                    <td>@(item.HuanLuyenVien?.HoTen ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

           

        <!-- Sidebar thông báo -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 position-sticky" style="top: 90px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-bell-fill me-1"></i> Thông báo</h6>

                    @if (thongBaoMoi > 0)
                    {
                        <span class="badge bg-warning text-dark">@thongBaoMoi mới</span>
                    }
                </div>

                <div class="card-body">

                    @if (!top3ThongBao.Any())
                    {
                        <p class="text-muted">Không có thông báo nào.</p>
                    }
                    else
                    {
                        foreach (var tb in top3ThongBao)
                        {
                            <div class="p-3 mb-3 rounded shadow-sm
                                 @(tb.DaDoc ? "bg-light" : "bg-warning bg-opacity-25 border border-warning")">

                                <div class="d-flex justify-content-between mb-1">
                                    <strong>@tb.TieuDe</strong>

                                    @if (!tb.DaDoc)
                                    {
                                        <span class="badge text-bg-danger">Mới</span>
                                    }
                                </div>

                                <div class="text-muted small">@tb.NoiDung</div>
                                <div class="text-muted small mt-1">
                                    <i class="bi bi-clock me-1"></i>
                                    @tb.NgayGui.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        }
                    }

                    <div class="text-end mt-2">
                        <a href="/ThongBao/Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
