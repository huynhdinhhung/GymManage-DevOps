@model GYM_Manage.Controllers.AboutViewModel
@{
    ViewData["Title"] = "Về chúng tôi";
}

<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">Về GYM Center</h1>
                <p class="lead mb-4">Chúng tôi là trung tâm thể hình hiện đại với đội ngũ huấn luyện viên chuyên nghiệp và trang thiết bị tập luyện tiên tiến.</p>
                <p class="mb-5">Sứ mệnh của chúng tôi là giúp mọi người đạt được mục tiêu sức khỏe và thể hình thông qua các chương trình tập luyện khoa học và hiệu quả.</p>
                <a href="#trainers" class="btn btn-light btn-lg px-4 me-2">Đội ngũ huấn luyện viên</a>
                <a href="#equipment" class="btn btn-outline-light btn-lg px-4">Trang thiết bị</a>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1170&q=80"
                     class="img-fluid rounded-3 shadow" alt="Gym">
            </div>
        </div>
    </div>
</section>

<!-- Our Story Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <img src="https://images.unsplash.com/photo-1571902943202-507ec2618e8f?auto=format&fit=crop&w=1075&q=80"
                     class="img-fluid rounded-3 shadow" alt="Gym Interior">
            </div>

            <div class="col-lg-6">
                <div class="ps-lg-4">
                    <h6 class="text-primary fw-bold">CÂU CHUYỆN CỦA CHÚNG TÔI</h6>
                    <h2 class="display-5 fw-bold mb-4">Hơn 10 năm kinh nghiệm trong lĩnh vực thể hình</h2>
                    <p class="lead">GYM Center được thành lập nhằm mang đến trải nghiệm tập luyện tốt nhất cho mọi người.</p>
                    <p>Chúng tôi cung cấp không gian tập luyện hiện đại, huấn luyện viên chuyên nghiệp và thiết bị đạt chuẩn quốc tế.</p>

                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary rounded-circle p-3 me-3">
                                    <i class="bi bi-people-fill text-white fs-4"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1">Huấn luyện viên chuyên nghiệp</h5>
                                    <p class="mb-0 text-muted">Đội ngũ HLV giàu kinh nghiệm</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary rounded-circle p-3 me-3">
                                    <i class="bi bi-gear-fill text-white fs-4"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1">Thiết bị hiện đại</h5>
                                    <p class="mb-0 text-muted">Máy móc nhập khẩu chính hãng</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trainers Section -->
<section id="trainers" class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">
            <h6 class="text-primary fw-bold">ĐỘI NGŨ CỦA CHÚNG TÔI</h6>
            <h2 class="display-5 fw-bold">Huấn Luyện Viên Chuyên Nghiệp</h2>
            <p class="lead mx-auto" style="max-width: 700px;">
                Đội ngũ huấn luyện viên giàu kinh nghiệm và chuyên môn cao, luôn sẵn sàng hỗ trợ bạn.
            </p>
        </div>

        <div class="row g-4">
            @foreach (var hlv in Model.HuanLuyenViens)
            {
                var hoTen = hlv.NguoiDung?.HoTen ?? "HLV";
                var avatar = string.IsNullOrEmpty(hlv.AnhDaiDien)
                ? $"https://ui-avatars.com/api/?name={hoTen}&background=4e73df&color=fff&size=256"
                : hlv.AnhDaiDien;

                <div class="col-md-6 col-lg-3">
                    <a href="/HuanLuyenVien/Details/@hlv.MaHuanLuyenVien" class="text-decoration-none text-dark">

                        <div class="card border-0 shadow-sm h-100 trainer-card">


                        <div class="position-relative">
                            <img src="@avatar"
                                 class="card-img-top"
                                 alt="@hoTen"
                                 style="height: 280px; object-fit: cover;">

                            <div class="trainer-social">
                                <a href="#" class="btn btn-primary btn-sm rounded-circle"><i class="bi bi-facebook"></i></a>
                                <a href="#" class="btn btn-primary btn-sm rounded-circle"><i class="bi bi-instagram"></i></a>
                                <a href="#" class="btn btn-primary btn-sm rounded-circle"><i class="bi bi-linkedin"></i></a>
                            </div>
                        </div>

                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold mb-1">@hoTen</h5>
                            <p class="text-primary mb-2">@hlv.ChuyenMon</p>
                        </div>

                    </div>
                </div>
            }
        </div>

    </div>
    

</section>

<!-- Equipment Section -->
<section id="equipment" class="py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h6 class="text-primary fw-bold">TRANG THIẾT BỊ</h6>
            <h2 class="display-5 fw-bold">Thiết Bị Hiện Đại</h2>
            <p class="lead mx-auto" style="max-width: 700px;">
                Chúng tôi đầu tư vào thiết bị hiện đại đảm bảo hiệu quả tập luyện tối đa.
            </p>
        </div>

        <div id="equipmentScroll" class="d-flex overflow-auto gap-4 px-2" style="scroll-snap-type: x mandatory;">

            <!-- 1. Máy chạy bộ -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
