                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy chạy bộ</h5></div>
                </div>
            </div>

            <!-- 2. Máy kéo xô -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://cdn.pixabay.com/photo/2022/10/18/12/31/fitness-rings-7530142_1280.jpg"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy kéo xô</h5></div>
                </div>
            </div>

            <!-- 3. Máy tập chân -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://thethaominhphu.com/wp-content/uploads/2017/04/may-tap-dap-chan-dui-nghieng-1039.jpeg"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy tập chân Leg Press</h5></div>
                </div>
            </div>

            <!-- 4. Dumbbells -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRGxrJSNmGI7tpIoyRoOLLV1Abs1Rh_pixCBQ&s"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Tạ đơn</h5></div>
                </div>
            </div>

            <!-- 5. Barbell -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://cdn.pixabay.com/photo/2019/01/20/00/48/weights-3942914_1280.jpg"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Tạ đòn Barbell</h5></div>
                </div>
            </div>

            <!-- 6. Máy đạp xe -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQKz6mAb81-17sB53yZuNI8NgMwQuG9v7MHLg&s"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Xe đạp tập</h5></div>
                </div>
            </div>

            <!-- 7. Máy kéo cáp -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://fitequipment.vn/wp-content/uploads/2022/01/May-keo-cap-da-nang-dhz-E7017A-3.jpg"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy kéo cáp</h5></div>
                </div>
            </div>

            <!-- 8. Ghế tập tạ -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTHXK-ghxKG-7Tvs-LH1PC5ZXxs0E0pwDN0ng&s"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Ghế Bench Press</h5></div>
                </div>
            </div>

            <!-- 9. Máy tập bụng -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTpctXbE_ig_DuIUhSjUD05zEC2QxsF5Visvw&s"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy tập bụng</h5></div>
                </div>
            </div>

            <!-- 10. Máy Smith -->
            <div class="flex-shrink-0" style="width: 300px; scroll-snap-align: start;">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRHmUWquu5vDLmgwgvJMeBGABXvPeVdXE-mUw&s"
                         class="card-img-top" style="height:220px;object-fit:cover;" />
                    <div class="card-body"><h5 class="card-title fw-bold">Máy Smith</h5></div>
                </div>
            </div>

        </div>

    </div>
</section>

<script>
    const scrollContainer = document.getElementById('equipmentScroll');
    const cardWidth = 300 + 16;
    let scrollIndex = 0;

    setInterval(() => {
        const visibleCards = Math.floor(scrollContainer.clientWidth / cardWidth);
        const totalCards = Math.floor(scrollContainer.scrollWidth / cardWidth);
        const maxIndex = totalCards - visibleCards;

        scrollIndex = (scrollIndex + 1) > maxIndex ? 0 : scrollIndex + 1;

        scrollContainer.scrollTo({
            left: scrollIndex * cardWidth,
            behavior: 'smooth'
        });
    }, 2000);
</script>

<!-- Why Choose Us Section -->
