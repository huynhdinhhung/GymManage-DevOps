<!DOCTYPE html>
<html lang="vi" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phòng GYM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout/_Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GYM_Manage.styles.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        /* Thiết lập biến CSS toàn cục để đảm bảo không bị ảnh hưởng bởi các CSS khác */
        :root {
            --chat-primary-color: #E83E8C;
            --chat-primary-dark: #D5307F;
        }

        /* Chatbox Styles */
        .chat-widget {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
        }

        .chat-button {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background-color: #E83E8C; /* Sử dụng màu hồng đậm rõ ràng thay vì var(--primary-color) */
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }

            .chat-button:hover {
                transform: scale(1.05);
                background-color: #D5307F; /* Màu đậm hơn khi hover */
            }

        .chat-container {
            position: absolute;
            bottom: 70px;
            right: 0;
            width: 350px;
            height: 450px;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            display: none;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            background-color: #E83E8C; /* Sử dụng màu giống nút chat */
            color: white;
            padding: 15px;
            font-weight: 600;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chat-body {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .chat-message {
            margin-bottom: 10px;
            max-width: 80%;
            padding: 10px 15px;
            border-radius: 18px;
            word-wrap: break-word;
        }

        .bot-message {
            background-color: #f0f0f0;
            align-self: flex-start;
            border-bottom-left-radius: 5px;
        }

        .user-message {
            background-color: #E83E8C; /* Sử dụng màu giống nút chat */
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 5px;
        }

        .chat-input-container {
            padding: 10px;
            border-top: 1px solid #e0e0e0;
            display: flex;
        }

        .chat-input {
            flex: 1;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 20px;
            outline: none;
        }

        .chat-send {
            border: none;
            background-color: #E83E8C; /* Sử dụng màu giống nút chat */
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            margin-left: 10px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            .chat-send:hover {
                background-color: #D5307F; /* Màu đậm hơn khi hover */
            }

        .typing-indicator {
            display: flex;
            padding: 10px 15px;
            background-color: #f0f0f0;
            border-radius: 18px;
            border-bottom-left-radius: 5px;
            align-self: flex-start;
            margin-bottom: 10px;
            width: fit-content;
        }

            .typing-indicator span {
                height: 8px;
                width: 8px;
                margin: 0 1px;
                background-color: #888;
                border-radius: 50%;
                display: inline-block;
                animation: typing 1s infinite ease-in-out;
            }

                .typing-indicator span:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .typing-indicator span:nth-child(3) {
                    animation-delay: 0.4s;
                }

        @@keyframes typing {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-5px);
            }

            100% {
                transform: translateY(0px);
            }
        }
    </style>
</head>

<body class="d-flex flex-column h-100">
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container d-flex justify-content-between align-items-center">
                <div>
                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-dumbbell-fill fs-4 me-2"></i>
                        <span>GYM Center</span>
                    </a>
                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="" asp-controller="GoiTap" asp-action="Index">
                                <i class="bi bi-card-list me-1"></i> Đăng ký tập
                            </a>
                        </li>

                        <li class="nav-item position-relative">
                            <a class="nav-link d-flex align-items-center position-relative"
                               asp-area=""
                               asp-controller="LichTap"
                               asp-action="Index">

                                <i class="bi bi-list-check me-1"></i> Lịch tập của tôi

                                @if (ViewBag.ThongBaoMoi != null && ViewBag.ThongBaoMoi > 0)
                                {
                                    <span class="badge bg-danger rounded-pill position-absolute"
                                          style="top: 0px; right: -12px; font-size: 0.7rem;">
                                        @ViewBag.ThongBaoMoi
                                    </span>
                                }
                            </a>
                        </li>


                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="" asp-controller="BaiViet" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i> Bài viết
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="" asp-controller="Contact" asp-action="Index">
                                <i class="bi bi-chat-dots me-1"></i> Liên hệ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="" asp-controller="About" asp-action="Index">
                                <i class="bi bi-chat-dots me-1"></i> Về chúng tôi
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav auth-buttons d-flex align-items-center">
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> @Context.Session.GetString("UserName")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                                    @if (Context.Session.GetString("UserRole") == "Admin")
                                    {
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Quản trị</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link login-btn d-flex align-items-center" asp-area="" asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-person-circle me-1"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link register-btn d-flex align-items-center" asp-area="" asp-controller="Auth" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Chatbox Widget -->
    <div class="chat-widget">
        <div class="chat-button" id="chatButton" style="z-index: 9999;">
            <i class="bi bi-chat-dots-fill fs-4"></i>
        </div>
        <div class="chat-container" id="chatContainer" style="display: none;">
            <div class="chat-header">
                <div class="d-flex align-items-center">
                    <i class="bi bi-dumbbell-fill me-2"></i> GYM Hỗ Trợ
                </div>
                <i class="bi bi-x-lg" id="closeChat" style="cursor: pointer;"></i>
            </div>
            <div class="chat-body" id="chatBody">
                <div class="chat-message bot-message">
                    Xin chào! Tôi là trợ lý ảo của GYM Center. Bạn cần hỗ trợ gì về lịch tập, gói tập, hoặc thông tin về phòng gym của chúng tôi?
                </div>
            </div>
            <div class="chat-input-container">
                <input type="text" class="chat-input" id="chatInput" placeholder="Nhập câu hỏi của bạn..." autofocus>
                <button class="chat-send" id="chatSend">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>

    <footer class="footer mt-1 py-4 bg-dark text-white">
        <div class="container-sm">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5>GYM Center</h5>
                    <p class="small text-wrap lh-lg">Chúng tôi cung cấp dịch vụ tập luyện chất lượng cao với các huấn luyện viên chuyên nghiệp và thiết bị hiện đại.</p>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#" class="text-white"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Liên hệ</h5>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-geo-alt me-2"></i> 123 Đường ABC, Quận XYZ, TP.HCM</li>
                        <li><i class="bi bi-telephone me-2"></i> (028) 1234 5678</li>
                        <li><i class="bi bi-envelope me-2"></i> info@gymcenter.com</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Giờ mở cửa</h5>
                    <ul class="list-unstyled">
                        <li>Thứ 2 - Thứ 6: 6:00 - 22:00</li>
                        <li>Thứ 7: 7:00 - 21:00</li>
                        <li>Chủ nhật: 8:00 - 20:00</li>
                    </ul>
                </div>
            </div>
            <hr class="my-2">
            <div class="text-center">
                &copy; @DateTime.Now.Year - GYM Center - <a class="text-white" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="successToast" class="toast border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header bg-success text-white">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong class="me-auto">Thông báo</strong>
                    <small>Vừa xong</small>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body bg-light">
                    <div class="d-flex align-items-center">
                        <div class="text-success me-2">
                            <i class="bi bi-check-circle-fill fs-4"></i>
                        </div>
                        <div>@TempData["SuccessMessage"]</div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById("successToast");
                var toast = new bootstrap.Toast(toastEl, {
                    delay: 4000,
                    animation: true,
                    autohide: true
                });
                toast.show();
            });
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="errorToast" class="toast border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header bg-danger text-white">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <small>Vừa xong</small>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body bg-light">
                    <div class="d-flex align-items-center">
                        <div class="text-danger me-2">
                            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                        </div>
                        <div>@TempData["ErrorMessage"]</div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById("errorToast");
                var toast = new bootstrap.Toast(toastEl, {
                    delay: 4000,
                    animation: true,
                    autohide: true
                });
                toast.show();
            });
        </script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Chatbox Functions
            const chatButton = document.getElementById('chatButton');
            const chatContainer = document.getElementById('chatContainer');
            const closeChat = document.getElementById('closeChat');
            const chatInput = document.getElementById('chatInput');
            const chatSend = document.getElementById('chatSend');
            const chatBody = document.getElementById('chatBody');

            // Đảm bảo các phần tử tồn tại trước khi thêm event listener
            if (!chatButton || !chatContainer || !closeChat || !chatInput || !chatSend || !chatBody) {
                console.error('Một hoặc nhiều phần tử chatbox không tồn tại');
                return;
            }

            // Predefined responses for gym-related questions
            const responses = {
                'giờ': 'Giờ mở cửa của chúng tôi là: \nThứ 2 - Thứ 6: 6:00 - 22:00 \nThứ 7: 7:00 - 21:00 \nChủ nhật: 8:00 - 20:00',
                'địa chỉ': 'Địa chỉ của GYM Center là: 123 Đường ABC, Quận XYZ, TP.HCM',
                'giá': 'Chúng tôi có nhiều gói tập với các mức giá khác nhau. Vui lòng truy cập mục "Đăng ký tập" để xem chi tiết hoặc liên hệ số điện thoại (028) 1234 5678.',
                'pt': 'Chúng tôi có đội ngũ huấn luyện viên chuyên nghiệp, giàu kinh nghiệm. Bạn có thể đăng ký PT khi chọn gói tập hoặc liên hệ trực tiếp tại quầy lễ tân.',
                'hội viên': 'Để trở thành hội viên, bạn cần đăng ký tài khoản trên website, sau đó chọn gói tập phù hợp tại mục "Đăng ký tập".',
                'thiết bị': 'GYM Center được trang bị đầy đủ các thiết bị tập luyện hiện đại bao gồm máy tập cardio, máy tập sức mạnh, khu tập tự do với tạ đa năng và nhiều thiết bị khác.',
                'lớp': 'Chúng tôi có nhiều lớp tập nhóm như: Yoga, Zumba, Spinning, Aerobic, và CrossFit. Lịch học được cập nhật hàng tuần tại bảng thông báo hoặc ứng dụng di động của chúng tôi.',
                'đăng ký': 'Bạn có thể đăng ký thành viên trực tuyến bằng cách nhấp vào nút "Đăng ký" ở góc phải trên cùng của trang web, hoặc trực tiếp tại quầy lễ tân của phòng tập.',
                'dinh dưỡng': 'Chúng tôi có dịch vụ tư vấn dinh dưỡng với các chuyên gia giàu kinh nghiệm. Bạn có thể đặt lịch tư vấn tại quầy lễ tân hoặc qua số điện thoại (028) 1234 5678.',
                'khuyến mãi': 'Hiện tại chúng tôi đang có chương trình ưu đãi giảm 20% cho gói tập 6 tháng và 30% cho gói tập 12 tháng. Vui lòng đăng ký trong tháng này để nhận ưu đãi!',
                'liên hệ': 'Bạn có thể liên hệ với chúng tôi qua số điện thoại (028) 1234 5678, email info@gymcenter.com hoặc trực tiếp tại 123 Đường ABC, Quận XYZ, TP.HCM.'
            };

            function addMessage(message, isUser = false) {
                const messageDiv = document.createElement('div');
                messageDiv.classList.add('chat-message');
                messageDiv.classList.add(isUser ? 'user-message' : 'bot-message');
                messageDiv.textContent = message;
                chatBody.appendChild(messageDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            }

            function showTypingIndicator() {
                const typingDiv = document.createElement('div');
                typingDiv.classList.add('typing-indicator');
                typingDiv.id = 'typingIndicator';
                typingDiv.innerHTML = '<span></span><span></span><span></span>';
                chatBody.appendChild(typingDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            }

            function removeTypingIndicator() {
                const typingIndicator = document.getElementById('typingIndicator');
                if (typingIndicator) {
                    typingIndicator.remove();
                }
            }

            function getBotResponse(userInput) {
                userInput = userInput.toLowerCase();

                // Check predefined responses
                for (const [keyword, response] of Object.entries(responses)) {
                    if (userInput.includes(keyword)) {
                        return response;
                    }
                }

                // Default responses based on common gym questions
                if (userInput.includes('xin chào') || userInput.includes('hi') || userInput.includes('hello')) {
                    return 'Xin chào! Tôi có thể giúp gì cho bạn về dịch vụ tại GYM Center?';
                } else if (userInput.includes('tập') && userInput.includes('mới')) {
                    return 'Đối với người mới tập, chúng tôi khuyên bạn nên đăng ký gói PT để được hướng dẫn kỹ thuật cơ bản và lên lịch tập phù hợp. Bạn cũng có thể tham khảo các bài viết hướng dẫn trên trang web của chúng tôi.';
                } else if (userInput.includes('dụng cụ') || userInput.includes('máy tập')) {
                    return 'GYM Center được trang bị đầy đủ các thiết bị hiện đại bao gồm máy tập cardio, máy tập sức mạnh, khu tự do với tạ đa năng và nhiều thiết bị khác. Bạn có thể tham quan phòng tập để biết thêm chi tiết.';
                } else if (userInput.includes('giảm cân') || userInput.includes('giảm mỡ')) {
                    return 'Để giảm cân hiệu quả, bạn nên kết hợp tập luyện cardio với tập luyện sức mạnh và chế độ dinh dưỡng hợp lý. Chúng tôi có các huấn luyện viên có thể giúp bạn lên kế hoạch giảm cân phù hợp.';
                } else if (userInput.includes('tăng cơ') || userInput.includes('tăng cân')) {
                    return 'Để tăng cơ, bạn cần tập trung vào các bài tập sức mạnh với cường độ cao và chế độ dinh dưỡng giàu protein. Các huấn luyện viên của chúng tôi có thể giúp bạn thiết kế lịch tập và chế độ ăn phù hợp.';
                } else if (userInput.includes('yoga') || userInput.includes('pilates')) {
                    return 'Chúng tôi có các lớp Yoga và Pilates vào các buổi sáng và tối trong tuần. Vui lòng kiểm tra lịch lớp học trên trang web hoặc ứng dụng của chúng tôi để biết thời gian cụ thể.';
                } else if (userInput.includes('phí') || userInput.includes('học phí')) {
                    return 'Phí thành viên của chúng tôi dao động từ 500.000đ đến 2.000.000đ mỗi tháng tùy theo gói dịch vụ. Chúng tôi cũng có các gói dài hạn với giá ưu đãi. Vui lòng truy cập mục "Đăng ký tập" để xem chi tiết.';
                } else if (userInput.includes('cảm ơn')) {
                    return 'Không có gì! Rất vui được hỗ trợ bạn. Nếu có thắc mắc gì thêm, đừng ngần ngại hỏi nhé!';
                } else {
                    return 'Cảm ơn bạn đã liên hệ. Để được hỗ trợ chi tiết, vui lòng liên hệ số điện thoại (028) 1234 5678 hoặc ghé quầy lễ tân tại phòng tập. Chúng tôi luôn sẵn sàng phục vụ bạn!';
                }
            }

            // Toggle chat container
            chatButton.addEventListener('click', function() {
                if (chatContainer.style.display === 'flex') {
                    chatContainer.style.display = 'none';
                } else {
                    chatContainer.style.display = 'flex';
                    chatInput.focus();
                }
            });

            closeChat.addEventListener('click', function() {
                chatContainer.style.display = 'none';
            });

            // Send message function
            function sendMessage() {
                const message = chatInput.value.trim();
                if (message) {
                    // Add user message
                    addMessage(message, true);
                    chatInput.value = '';

                    // Show typing indicator
                    showTypingIndicator();

                    // Set timeout to simulate typing
                    setTimeout(() => {
                        removeTypingIndicator();
                        // Add bot response
                        const response = getBotResponse(message);
                        addMessage(response);
                    }, 1500);
                }
            }

            // Send message on button click
            chatSend.addEventListener('click', sendMessage);

            // Send message on Enter key
            chatInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendMessage();
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
