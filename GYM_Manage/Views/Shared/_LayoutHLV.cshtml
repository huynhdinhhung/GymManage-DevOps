@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    var hlvName = HttpContextAccessor.HttpContext.Session.GetString("UserName") ?? "HLV";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HLV Panel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/Layout/_LayoutAdmin.css" asp-append-version="true" />

    <style>
        .sidebar {
            background: #1e1e2d !important;
        }

            .sidebar .nav-link.active {
                background: #4e73df !important;
                color: #fff !important;
            }

        .user-profile img {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            object-fit: cover;
        }
    </style>
</head>

<body>
    <div class="wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <i class="bi bi-person-badge fs-4 me-2"></i>
                <h5 class="m-0">HLV PANEL</h5>
            </div>

            <div class="sidebar-heading mb-2">Chức năng HLV</div>

            <ul class="nav flex-column" id="sidebarMenu">

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLVDashboard/Index">
                        <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_LichLamViec/Index">
                        <i class="bi bi-calendar-week"></i> <span>Lịch làm việc</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_CaLamViec/Index">
                        <i class="bi bi-clock-history"></i> <span>Ca làm việc</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_HocVien/Index">
                        <i class="bi bi-people"></i> <span>Học viên của tôi</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_LichTap/Index">
                        <i class="bi bi-list-check"></i> <span>Lịch tập học viên</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_YeuCauDoiLich/Index">
                        <i class="bi bi-shuffle"></i> <span>Yêu cầu đổi lịch</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/HLV/HLV_ThongBao/Index">
                        <i class="bi bi-bell"></i> <span>Thông báo</span>
                    </a>
                </li>

                <div class="sidebar-divider"></div>

                <div class="sidebar-heading">Tài khoản</div>

                <li class="nav-item">
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="nav-link bg-transparent border-0 text-start">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Đăng Xuất</span>
                        </button>
                    </form>
                </li>

            </ul>
        </div>

        <!-- MAIN CONTENT -->
        <div class="main-content" id="content">

            <!-- HEADER -->
            <header class="header d-flex align-items-center px-3">
                <button id="sidebarToggle" class="btn btn-link">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="ms-auto d-flex align-items-center">

                    <div class="dropdown">
                        <div class="user-profile d-flex align-items-center" data-bs-toggle="dropdown">
                            <img src="https://ui-avatars.com/api/?name=@hlvName&background=4e73df&color=fff">
                            <span class="ms-2">@hlvName</span>
                            <i class="bi bi-chevron-down ms-2 small"></i>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end lh-lg">
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng Xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                </div>
            </header>

            <!-- PAGE CONTENT -->
            <div class="content-area">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
            </div>

        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Toggle sidebar
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('content').classList.toggle('expanded');
        });

        // Highlight active menu
        const current = window.location.pathname.toLowerCase();
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href').toLowerCase();
            if (current.includes(href)) {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
