@model IEnumerable<GYM_Manage.Models.CaLamViec>
@{
    Layout = "~/Views/Shared/_LayoutHLV.cshtml";
    ViewData["Title"] = "Ca làm việc";
}

<h3 class="fw-bold mb-4">
    <i class="bi bi-clock-history"></i> Danh sách ca làm việc
</h3>

<table class="table table-bordered table-hover text-center">
    <thead class="table-light">
        <tr>
            <th>Tên ca</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var ca in Model)
        {
            <tr>
                <td>@ca.TenCa</td>
                <td>@ca.GioBatDau</td>
                <td>@ca.GioKetThuc</td>
            </tr>
        }
    </tbody>
</table>
