@model IEnumerable<GYM_Manage.Models.DangKyGoiTap>

@{
    ViewData["Title"] = "Học viên của tôi";
    Layout = "~/Views/Shared/_LayoutHLV.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            <i class="bi bi-people me-2"></i> Học viên của tôi
        </h5>
    </div>

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info d-flex align-items-center">
                <i class="bi bi-info-circle fs-5 me-2"></i>
                <div>Hiện tại bạn chưa có học viên nào.</div>
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Học viên</th>
                        <th>Số điện thoại</th>
                        <th>Gói tập</th>
                        <th>Ngày bắt đầu</th>
                        <th>Ngày kết thúc</th>
                        <th>Ca tập</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var hv in Model)
                    {
                        var lichVip = hv.ThanhVien?.LichTapThanhViens?
                        .OrderBy(l => l.NgayTap)
                        .FirstOrDefault();   // >> lấy lịch VIP của thành viên

                        <tr>
                            <td><strong>@hv.ThanhVien?.NguoiDung?.HoTen</strong></td>

                            <td>@hv.ThanhVien?.SoDienThoai</td>

                            <td>@hv.GoiTap?.TenGoiTap</td>

                            <td>@hv.NgayBatDau.ToString("dd/MM/yyyy")</td>

                            <td>@hv.NgayKetThuc.ToString("dd/MM/yyyy")</td>

                            <td>
                                @if (lichVip != null)
                                {
                                    <b>@lichVip.CaLamViec?.TenCa</b>
                                    <br />
                                    <small class="text-muted">
                                        @lichVip.CaLamViec?.GioBatDau.ToString(@"hh\:mm")
                                        -
                                        @lichVip.CaLamViec?.GioKetThuc.ToString(@"hh\:mm")
                                    </small>
                                }
                                else if (hv.CaLamViec != null)
                                {
                                    <b>@hv.CaLamViec.TenCa</b>
                                    <br />
                                    <small class="text-muted">
                                        @hv.CaLamViec.GioBatDau - @hv.CaLamViec.GioKetThuc
                                    </small>
                                }
                                else
                                {
                                    <span class="text-muted">Không có ca</span>
                                }
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        }
    </div>
</div>
