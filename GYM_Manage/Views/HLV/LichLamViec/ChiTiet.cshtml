@model GYM_Manage.Models.LichLamViecHLV
@{
    Layout = "~/Views/Shared/_LayoutHLV.cshtml";

    string GetThu(int t) => t switch
    {
        2 => "Thứ 2",
        3 => "Thứ 3",
        4 => "Thứ 4",
        5 => "Thứ 5",
        6 => "Thứ 6",
        7 => "Thứ 7",
        1 => "Chủ nhật",
        _ => "N/A"
    };
}

<h3 class="fw-bold mb-3">
    <i class="bi bi-calendar-check"></i> Chi tiết lịch làm việc
</h3>

<div class="card shadow-sm border-0 rounded-3 p-4 mt-2">

    <!-- THÔNG TIN HLV + NGÀY -->
    <div class="row mb-4">
        <div class="col-md-6">
            <p class="text-muted mb-1">Huấn luyện viên</p>
            <h5 class="fw-semibold">@Model.HuanLuyenVien?.HoTen</h5>
        </div>

        <div class="col-md-6">
            <p class="text-muted mb-1">Ngày làm việc</p>
            <h5 class="fw-semibold">@Model.NgayLamViec.ToString("dd/MM/yyyy")</h5>
        </div>
    </div>

    <hr />

    <!-- THÔNG TIN CHI TIẾT CA -->
    <div class="row mt-3">

        <div class="col-md-4">
            <p class="text-muted mb-1">Thứ</p>
            <h5 class="fw-semibold">@GetThu(Model.ThuTrongTuan)</h5>
        </div>

        <div class="col-md-4">
            <p class="text-muted mb-1">Ca làm</p>
            <h5 class="fw-semibold">@Model.CaLamViec?.TenCa</h5>
        </div>

        <div class="col-md-4">
            <p class="text-muted mb-1">Thời gian</p>
            <h5 class="fw-semibold">
                @Model.CaLamViec?.GioBatDau - @Model.CaLamViec?.GioKetThuc
            </h5>
        </div>

    </div>

    <!-- BACK BUTTON -->
    <div class="text-end mt-4">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

</div>
