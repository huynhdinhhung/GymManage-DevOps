@model IEnumerable<GYM_Manage.Models.LichLamViecHLV>
@{
    Layout = "~/Views/Shared/_LayoutHLV.cshtml";

    string GetThu(int t) => t switch
    {
        2 => "Thứ 2",
        3 => "Thứ 3",
        4 => "Thứ 4",
        5 => "Thứ 5",
        6 => "Thứ 6",
        7 => "Thứ 7",
        1 => "Chủ nhật",
        _ => "N/A"
    };
}

<h3 class="fw-bold mb-4">
    <i class="bi bi-calendar-week"></i> Lịch làm việc của bạn
</h3>

<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle text-center shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Ngày</th>
                <th>Thứ</th>
                <th>Ca</th>
                <th>Giờ làm</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var lich in Model)
            {
                bool isToday = lich.NgayLamViec.Date == DateTime.Today;

                <tr class="@(isToday ? "table-warning" : "")">
                    <td>
                        @lich.NgayLamViec.ToString("dd/MM/yyyy")
                        @if (isToday)
                        {
                            <span class="badge bg-danger ms-1">Hôm nay</span>
                        }
                    </td>

                    <td>@GetThu(lich.ThuTrongTuan)</td>

                    <td class="fw-semibold text-primary">
                        @lich.CaLamViec?.TenCa
                    </td>

                    <td class="text-secondary">
                        @lich.CaLamViec?.GioBatDau - @lich.CaLamViec?.GioKetThuc
                    </td>

                    <td>
                        <a asp-action="ChiTiet"
                           asp-route-id="@lich.MaLich"
                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                            <i class="bi bi-eye"></i> Xem
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
