@using GYM_Manage.Models

@{
    ViewData["Title"] = "Thanh Toán Gói Tập";
    Layout = "_Layout";

    var goiTap = ViewBag.GoiTap as GoiTap;
    var nguoiDung = ViewBag.NguoiDung as NguoiDung;

    // Lấy dữ liệu VIP (từ TempData.Peek trong controller)
    int? maHlvDaChon = ViewBag.MaHuanLuyenVien != null ? Convert.ToInt32(ViewBag.MaHuanLuyenVien) : null;
    int? thuDaChon = ViewBag.ThuTrongTuan != null ? Convert.ToInt32(ViewBag.ThuTrongTuan) : null;
    int? maCaDaChon = ViewBag.MaCa != null ? Convert.ToInt32(ViewBag.MaCa) : null;

    var danhSachHLV = ViewBag.DanhSachHLV as List<HuanLuyenVien>;

    HuanLuyenVien hlvDaChon = (maHlvDaChon != null && danhSachHLV != null)
        ? danhSachHLV.FirstOrDefault(h => h.MaHuanLuyenVien == maHlvDaChon.Value)
        : null;

    string ThuText(int thu)
    {
        return thu switch
        {
            1 => "Thứ 2",
            2 => "Thứ 3",
            3 => "Thứ 4",
            4 => "Thứ 5",
            5 => "Thứ 6",
            6 => "Thứ 7",
            7 => "Chủ nhật",
            _ => "Không rõ"
        };
    }
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold display-4">Thanh Toán Gói Tập</h1>
        <p class="lead text-muted">Hoàn tất thanh toán để kích hoạt gói tập của bạn</p>
    </div>

    <div class="row">

        <!-- ----------------------------- -->
        <!--        THÔNG TIN GÓI TẬP         -->
        <!-- ----------------------------- -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow-lg border-0 h-100">

                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-cart-check me-2"></i>Thông tin đơn hàng</h4>
                </div>

                <div class="card-body p-4">

                    <div class="d-flex mb-4">
                        <img src="@(string.IsNullOrEmpty(goiTap.AnhDemo) ? "/images/default-package.jpg" : goiTap.AnhDemo)"
                             class="rounded me-3"
                             style="width:80px;height:80px;object-fit:cover;" />

                        <div>
                            <h5 class="fw-bold">@goiTap.TenGoiTap</h5>
                            <p class="text-muted mb-0">Thời hạn: @goiTap.ThoiHan ngày</p>
                        </div>
                    </div>

                    <div class="bg-light p-3 rounded mb-4">
                        <h5 class="fw-bold mb-3">Chi tiết gói tập</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giá gói tập:</span>
                            <span class="fw-bold">@goiTap.GiaTien.ToString("N0") VNĐ</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Tổng cộng:</span>
                            <span class="fw-bold text-primary fs-5">@goiTap.GiaTien.ToString("N0") VNĐ</span>
                        </div>
                    </div>

                    <!-- THÔNG TIN KHÁCH HÀNG -->
                    <div class="bg-light p-3 rounded mb-4">
                        <h5 class="fw-bold mb-3">Thông tin khách hàng</h5>
                        <p><strong>Họ tên:</strong> @nguoiDung.HoTen</p>
                        <p><strong>Email:</strong> @nguoiDung.Email</p>
                    </div>

                    <!-- VIP -->
                    @if (hlvDaChon != null)
                    {
                        <div class="bg-warning bg-opacity-25 p-3 rounded mb-4">
                            <h5 class="fw-bold text-danger mb-3">Lịch huấn luyện (VIP)</h5>
                            <p><strong>HLV:</strong> @hlvDaChon.HoTen</p>
                            <p><strong>Thứ:</strong> @ThuText(thuDaChon.Value)</p>
                            <p><strong>Ca:</strong> @maCaDaChon</p>
                        </div>
                    }

                </div>
            </div>
        </div>

        <!-- ----------------------------- -->
        <!--          FORM THANH TOÁN         -->
        <!-- ----------------------------- -->
        <div class="col-lg-6">
            <div class="card shadow-lg border-0">

                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-credit-card me-2"></i>Phương thức thanh toán</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="ThanhToan" method="post" id="paymentForm">

                        <input type="hidden" name="maGoiTap" value="@goiTap.MaGoiTap" />
                        <input type="hidden" name="maNguoiDung" value="@nguoiDung.MaNguoiDung" />

                        <!-- ❗ ALWAYS SEND HLV + THU + CA -->
                        <input type="hidden" name="MaHuanLuyenVien" value="@maHlvDaChon" />
                        <input type="hidden" name="ThuTrongTuan" value="@thuDaChon" />
                        <input type="hidden" name="MaCa" value="@maCaDaChon" />

                        <!-- Thông tin cá nhân -->
                        <h5 class="fw-bold mb-3">Thông tin cá nhân</h5>

                        <div class="mb-3">
                            <label class="form-label">Ngày sinh</label>
                            <input type="date" name="ngaySinh" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Giới tính</label>
                            <select name="gioiTinh" class="form-select" required>
                                <option value="">-- Chọn giới tính --</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" name="soDienThoai" maxlength="15" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ</label>
                            <textarea name="diaChi" rows="2" class="form-control" required></textarea>
                        </div>

                        <!-- PHƯƠNG THỨC THANH TOÁN -->
                        <h5 class="fw-bold mt-4 mb-3">Chọn phương thức thanh toán</h5>

                        <div class="form-check p-3 border rounded mb-3">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" id="banking" value="ChuyenKhoan" checked />
                            <label class="form-check-label fw-bold" for="banking">
                                <i class="bi bi-bank fs-4 me-2"></i> Chuyển khoản ngân hàng
                            </label>

                            <div id="bankingQR" class="mt-3">
                                <img src="/images/nganhang/nh.jpg" style="max-width:300px;" class="img-thumbnail" />
                            </div>
                        </div>

                        <div class="form-check p-3 border rounded mb-3 bg-light">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" id="momo" value="MoMo" />
                            <label class="form-check-label fw-bold" for="momo">
                                <i class="bi bi-wallet2 fs-4 me-2"></i> Ví MoMo
                            </label>

                            <div id="momoBtnWrap" class="mt-3" style="display:none;">
                                <button type="button" class="btn btn-momo w-100" onclick="submitMomoPayment()">
                                    Thanh toán MoMo
                                </button>
                            </div>
                        </div>

                        <div class="form-check p-3 border rounded mb-3 bg-light">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" id="vnpay" value="VNPay" />
                            <label class="form-check-label fw-bold" for="vnpay">
                                <i class="bi bi-credit-card fs-4 me-2 text-primary"></i> VNPay
                            </label>
                        </div>

                        <div class="form-check p-3 border rounded mb-4">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" id="cash" value="TienMat" />
                            <label class="form-check-label fw-bold" for="cash">
                                <i class="bi bi-cash-coin fs-4 me-2 text-success"></i> Tiền mặt tại phòng tập
                            </label>
                        </div>

                        <button class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-lock-fill me-2"></i> Xác nhận thanh toán
                        </button>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-momo {
        background: linear-gradient(135deg, #ff5e62, #ff9966);
        color: white;
        font-weight: bold;
    }
</style>

<script>
    function updatePaymentUI() {
        document.getElementById("bankingQR").style.display =
            document.getElementById("banking").checked ? "block" : "none";

        document.getElementById("momoBtnWrap").style.display =
            document.getElementById("momo").checked ? "block" : "none";
    }

    window.onload = updatePaymentUI;

    document.querySelectorAll("input[name='phuongThucThanhToan']")
        .forEach(el => el.addEventListener("change", updatePaymentUI));

    function submitMomoPayment() {
        const form = document.getElementById("paymentForm");
        form.action = "/Payment/CreatePaymentMomo";
        form.submit();
    }
</script>
