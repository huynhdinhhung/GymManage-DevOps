@using GYM_Manage.Models
@model GYM_Manage.Models.GoiTap

@{
    ViewData["Title"] = "Đăng Ký Gói Tập";
    var user = ViewBag.NguoiDung as NguoiDung;
    var danhSachHLV = ViewBag.DanhSachHLV as List<HuanLuyenVien>;
    var isVip = Model.LoaiGoi?.Trim().ToLower().Contains("vip") == true;
}

<div class="container py-5">
    <!-- Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="fw-bold display-4 mb-3">Đăng Ký Gói Tập</h1>
            <p class="lead text-muted">Hoàn tất đăng ký gói tập phù hợp với bạn</p>
        </div>
    </div>

    <div class="row">

        <!-- LEFT: GÓI TẬP -->
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-lg h-100">

                <div class="position-relative">
                    <img src="@(string.IsNullOrEmpty(Model.AnhDemo) ? "/images/default-package.jpg" : Model.AnhDemo)"
                         class="card-img-top"
                         alt="@Model.TenGoiTap"
                         style="height:300px;object-fit:cover;">

                    @if (Model.TrangThai == "KhuyenMai")
                    {
                        <div class="position-absolute top-0 end-0 bg-warning text-dark p-2 m-2 rounded-pill">
                            <i class="bi bi-tag-fill"></i> Khuyến mãi
                        </div>
                    }
                </div>

                <div class="card-body">
                    <h3 class="fw-bold">@Model.TenGoiTap</h3>
                    <div class="d-flex justify-content-between align-items-center my-3">
                        <span class="badge bg-primary fs-6 px-3 py-2">@Model.ThoiHan ngày</span>
                        <h3 class="text-primary mb-0">@Model.GiaTien.ToString("N0") VNĐ</h3>
                    </div>
                    <p class="text-muted">@Model.MoTa</p>

                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-clock me-2"></i>Thời hạn:</span>
                        <span class="fw-bold">@Model.ThoiHan ngày</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-currency-dollar me-2"></i>Giá:</span>
                        <span class="fw-bold">@Model.GiaTien.ToString("N0") VNĐ</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: FORM -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg">

                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-clipboard-check me-2"></i> Xác nhận đăng ký</h4>
                </div>

                <div class="card-body p-4">

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form id="dangKyForm" asp-action="DangKy" method="post" asp-route-id="@Model.MaGoiTap">
                        @Html.AntiForgeryToken()

                        <!-- USER INFO -->
                        @if (user != null)
                        {
                            <div class="mb-4">
                                <h5 class="fw-bold">Thông tin tài khoản</h5>
                                <div class="bg-light p-3 rounded">
                                    <p><strong>Họ tên:</strong> @user.HoTen</p>
                                    <p><strong>Email:</strong> @user.Email</p>
                                    <p><strong>Trạng thái VIP:</strong> @(user.IsVip ? "VIP" : "Thường")</p>
                                </div>
                            </div>
                        }

                        <!-- VIP – CHỌN HLV -->
                        @if (isVip)
                        {
                            <div class="mb-4">
                                <h5 class="fw-bold">Chọn Huấn Luyện Viên (VIP)</h5>

                                <select id="hlvSelect" class="form-select" required>
                                    <option value="">-- Chọn HLV --</option>
                                    @foreach (var hlv in danhSachHLV ?? new List<HuanLuyenVien>())
                                    {
                                        <option value="@hlv.MaHuanLuyenVien">@hlv.HoTen</option>
                                    }
                                </select>

                                <div id="lichHLV" class="mt-3"></div>
                            </div>
                        }

                        <!-- TERMS -->
                        <div class="mb-4">
                            <h5 class="fw-bold">Điều khoản</h5>

                            <div class="bg-light p-3 rounded mb-2" style="max-height:150px;overflow-y:auto;">
                                <p>1. Gói tập không hoàn tiền.</p>
                                <p>2. Không chuyển nhượng.</p>
                                <p>3. Tuân thủ nội quy phòng tập.</p>
                            </div>

                            <div class="form-check">
                                <input type="checkbox" required class="form-check-input" id="accept">
                                <label class="form-check-label" for="accept">Tôi đồng ý với điều khoản</label>
                            </div>
                        </div>

                        <!-- SUBMIT -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-2"></i> Xác nhận
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>

                        <!-- HIDDEN SEND -->
                        <input type="hidden" id="MaHuanLuyenVien" name="MaHuanLuyenVien" />
                        <input type="hidden" id="ThuTrongTuan" name="ThuTrongTuan" />
                        <input type="hidden" id="MaCa" name="MaCa" />
                        <input type="hidden" id="IsVip" value="@(isVip.ToString().ToLower())" />
                    </form>

                </div>
            </div>
        </div>

    </div>
</div>

<!-- AJAX + LOGIC -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(function () {

        // Load lịch khi chọn HLV
        $("#hlvSelect").change(function () {
            const hlvId = $(this).val();
            $("#MaHuanLuyenVien").val(hlvId);

            if (!hlvId) {
                $("#lichHLV").html("");
                return;
            }

            $.get(`/GoiTap/GetLichHLV?hlvId=${hlvId}`, function (data) {

                if (!data || data.length === 0) {
                    $("#lichHLV").html("<p class='text-danger mt-2'>HLV chưa có lịch làm việc.</p>");
                    return;
                }

                let html = `
                    <h5 class="mt-3 fw-bold">Lịch làm việc của HLV</h5>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Thứ</th>
                                <th>Ca</th>
                                <th>Giờ</th>
                                <th>Chọn</th>
                            </tr>
                        </thead>
                        <tbody>
                `;

                data.forEach(item => {
                    html += `
                        <tr>
                            <td>${item.thu}</td>
                            <td>${item.ca}</td>
                            <td>${item.gio}</td>
                            <td>
                                <input type="radio"
                                       name="chonLich"
                                       class="chon-lich"
                                       value="${item.maCa}"
                                       data-thu="${item.thu}">
                            </td>
                        </tr>`;
                });

                html += "</tbody></table>";

                $("#lichHLV").html(html);
            });
        });

        // Khi chọn radio → cập nhật hidden input
        $(document).on("change", ".chon-lich", function () {
            const thu = $(this).data("thu");
            const maCa = $(this).val();

            $("#ThuTrongTuan").val(thu);
            $("#MaCa").val(maCa);

            console.log("Update:", thu, maCa);
        });

        // Validate VIP trước khi submit
        $("#dangKyForm").on("submit", function (e) {

            const isVip = $("#IsVip").val() === "true";

            const maHlv = $("#MaHuanLuyenVien").val();
            const thu = $("#ThuTrongTuan").val();
            const maCa = $("#MaCa").val();

            if (isVip) {
                if (!maHlv || !thu || !maCa) {
                    e.preventDefault();
                    alert("Vui lòng chọn đầy đủ HLV và lịch làm việc!");
                }
            }
        });
    });
</script>
