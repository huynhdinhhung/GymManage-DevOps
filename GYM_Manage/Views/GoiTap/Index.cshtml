@model IEnumerable<GYM_Manage.Models.GoiTap>

@{
    ViewData["Title"] = "Gói Tập";
    var user = ViewBag.User as GYM_Manage.Models.NguoiDung;
}

<div class="container py-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="fw-bold display-4">Gói Tập Gym</h1>
        <p class="lead text-muted">Lựa chọn gói tập phù hợp với mục tiêu của bạn</p>

        <!-- Search -->
        <div class="col-md-6 mx-auto mt-4">
            <form asp-action="Search" method="get">
                <div class="input-group shadow-lg rounded-pill overflow-hidden">

                    <input type="text" name="keyword"
                           class="form-control border-0 py-3 ps-4"
                           placeholder="Tìm kiếm gói tập..." />

                    <input type="number" name="soNgay" min="1"
                           class="form-control border-0 border-start py-3"
                           placeholder="Số ngày tối đa" />

                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-search me-1"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>


    <!-- List Packages -->
    <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-3">

        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm package-card">

                    <!-- Image -->
                    <div class="position-relative">
                        <img src="@(string.IsNullOrEmpty(item.AnhDemo) ? "/images/default-package.jpg" : item.AnhDemo)"
                             class="card-img-top"
                             alt="@item.TenGoiTap"
                             style="height: 200px; object-fit: cover;" />

                        <!-- TAG KHUYẾN MÃI -->
                        @if (item.TrangThai?.ToLower() == "khuyến mãi" || item.TrangThai?.ToLower() == "khuyến mại")
                        {
                            <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2 px-3 py-2 rounded-pill">
                                <i class="bi bi-tag-fill me-1"></i> Khuyến mãi
                            </span>
                        }

                        <!-- TAG VIP -->
                        @if (item.LoaiGoi?.ToUpper() == "VIP")
                        {
                            <span class="badge bg-danger text-white position-absolute top-0 start-0 m-2 px-3 py-2 rounded-pill fw-bold">
                                <i class="bi bi-star-fill me-1"></i> VIP
                            </span>
                        }
                    </div>


                    <!-- Body -->
                    <div class="card-body d-flex flex-column">

                        <h5 class="fw-bold">@item.TenGoiTap</h5>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-primary rounded-pill">@item.ThoiHan ngày</span>
                            <h4 class="text-primary mb-0">@item.GiaTien.ToString("N0") VNĐ</h4>
                        </div>

                        <p class="text-muted flex-grow-1">
                            @(item.MoTa?.Length > 100 ? item.MoTa.Substring(0, 100) + "..." : item.MoTa)
                        </p>

                        <!-- Buttons -->
                        <div class="d-grid gap-2">

                            <!-- Xem chi tiết -->
                            <a asp-action="Details" asp-route-id="@item.MaGoiTap"
                               class="btn btn-outline-primary">
                                <i class="bi bi-info-circle me-1"></i> Xem chi tiết
                            </a>

                            <!-- Đăng ký -->
                            @if (item.LoaiGoi?.ToUpper() == "VIP")
                            {
                                if (user == null)
                                {
                                    <!-- Chưa đăng nhập -->
                                    <a asp-controller="Auth" asp-action="Login"
                                       class="btn btn-secondary">
                                        <i class="bi bi-lock-fill me-1"></i> Chỉ dành cho VIP
                                    </a>
                                }
                                else if (!user.IsVip)
                                {
                                    <!-- Login nhưng chưa đạt VIP -->
                                    <button class="btn btn-secondary" disabled>
                                        <i class="bi bi-lock-fill me-1"></i> Chỉ dành cho VIP
                                    </button>
                                }
                                else
                                {
                                    <!-- VIP thật -->
                                    <a asp-action="DangKy" asp-route-id="@item.MaGoiTap"
                                       class="btn btn-warning text-dark fw-bold">
                                        <i class="bi bi-star-fill me-1"></i> Đăng ký VIP
                                    </a>
                                }
                            }
                            else
                            {
                                <!-- Gói thường -->
                                <a asp-action="DangKy" asp-route-id="@item.MaGoiTap"
                                   class="btn btn-primary">
                                    <i class="bi bi-check-circle me-1"></i> Đăng ký ngay
                                </a>
                            }

                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-transparent">
                        <small class="text-muted">
                            <i class="bi bi-clock me-1"></i> @item.ThoiHan ngày
                        </small>

                        <small class="text-muted float-end">
                            <i class="bi bi-people-fill me-1"></i> Mọi đối tượng
                        </small>
                    </div>

                </div>
            </div>
        }
    </div>


    <!-- No Result -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h3 class="mt-3">Không tìm thấy gói tập nào!</h3>
            <p class="text-muted">Hãy thử từ khóa khác hoặc điều kiện lọc khác.</p>
            <a asp-action="Index" class="btn btn-outline-primary mt-3">Xem tất cả gói tập</a>
        </div>
    }

</div>

<style>
    .package-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 22px rgba(0, 0, 0, 0.15) !important;
        transition: .25s ease-in-out;
    }
</style>
