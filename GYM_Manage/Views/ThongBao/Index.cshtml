@model IEnumerable<GYM_Manage.Models.ThongBao>

@{
    ViewData["Title"] = "Thông báo";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string GetIcon(string type)
    {
        return type switch
        {
            "HLVThayThe" => "bi-person-fill-exclamation text-warning",
            "LichTapTrongNgay" => "bi-calendar-check text-success",
            "DoiLich" => "bi-arrow-repeat text-primary",
            "DangKyGoiTap" => "bi-bag-check text-info",
            "AdminDuyet" => "bi-shield-check text-primary",
            _ => "bi-info-circle text-secondary"
        };
    }

    string GetBadge(string type)
    {
        return type switch
        {
            "HLVThayThe" => "warning",
            "LichTapTrongNgay" => "success",
            "DoiLich" => "info",
            "DangKyGoiTap" => "primary",
            _ => "secondary"
        };
    }
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">
            <i class="bi bi-bell-fill me-2"></i> Thông báo
        </h3>

        @if (Model.Any(x => !x.DaDoc))
        {
            <form asp-action="MarkAllAsRead" method="post">
                <button class="btn btn-sm btn-primary shadow-sm">
                    <i class="bi bi-check2-all me-1"></i> Đánh dấu tất cả đã đọc
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            <i class="bi bi-info-circle fs-3"></i>
            <div class="mt-2">Hiện bạn không có thông báo nào.</div>
        </div>
    }
    else
    {
        <ul class="list-group shadow-sm">

            @foreach (var tb in Model)
            {
                <li class="list-group-item border-0 border-bottom py-3 notification-item
                    d-flex justify-content-between align-items-start
                    @(tb.DaDoc ? "" : "bg-light bg-opacity-50")">

                    <div class="d-flex">
                        <!-- Icon -->
                        <div class="me-3 pt-1">
                            <i class="bi @GetIcon(tb.LoaiThongBao) fs-4"></i>
                        </div>

                        <div>
                            <!-- Tiêu đề -->
                            <h6 class="fw-bold mb-1">
                                @tb.TieuDe

                                <span class="badge bg-@GetBadge(tb.LoaiThongBao) ms-2">
                                    @tb.LoaiThongBao
                                </span>
                            </h6>

                            <!-- Nội dung -->
                            <div class="text-muted">@tb.NoiDung</div>

                            <!-- Thời gian -->
                            <small class="text-secondary d-block mt-1">
                                <i class="bi bi-clock me-1"></i>
                                @tb.NgayGui.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    </div>

                    @if (!tb.DaDoc)
                    {
                        <span class="badge text-bg-danger align-self-start">Mới</span>
                    }
                </li>
            }
        </ul>
    }
</div>

<style>
    .notification-item:hover {
        background: rgba(0, 0, 0, 0.05) !important;
        cursor: pointer;
        transition: 0.2s;
    }
</style>
